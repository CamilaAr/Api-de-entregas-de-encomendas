# Copie para .env e preencha (nunca commite o .env)

# Banco (ex.: Docker compose na raiz — usuário/senha/db padrão do compose)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rocketlog?schema=public

# Segredo do JWT (troque por um valor forte em produção)
JWT_SECRET=dev-secret-replace-in-production
